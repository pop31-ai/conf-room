{
  "name": "conf-room-desktop",
  "version": "1.0.0",
  "description": "Десктопный клиент конференц-комнаты (Windows/Linux)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win --x64",
    "build-linux": "electron-builder --linux",
    "build": "electron-builder"
  },
  "dependencies": {
    "electron": "^28.0.0"
  },
  "build": {
    "appId": "conf.room.desktop",
    "productName": "Конференц-комната",
    "win": {
      "target": "nsis",
      "icon": null
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": null
    }
  }
}
