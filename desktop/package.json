{
  "name": "conf-room",
  "version": "1.0.0",
  "description": "Голосовая комната — десктопный клиент",
  "main": "main.js",
  "author": "conf-room",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:linux": "electron-builder --linux --x64",
    "build": "electron-builder --win --linux --x64"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "conf.room.desktop",
    "productName": "Конференц-комната",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Конференц-комната",
      "installerLanguages": ["russian"],
      "language": "2058"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.png",
      "category": "AudioVideo",
      "desktop": {
        "Name": "Конференц-комната",
        "Comment": "Голосовая конференция",
        "Categories": "AudioVideo;Audio;Network;"
      }
    }
  }
}
